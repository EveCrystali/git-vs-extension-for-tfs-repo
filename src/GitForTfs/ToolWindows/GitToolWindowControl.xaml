<UserControl x:Class="GitForTfs.ToolWindows.GitToolWindowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vsshell="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
             xmlns:conv="clr-namespace:GitForTfs.Mvvm"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="360"
             Background="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBackgroundKey}}"
             Foreground="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}"
             Name="Root">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis" />

        <!-- ============================================================
             Theming. Everything below binds to Visual Studio environment
             colors (VsBrushes) via DynamicResource so the tool window
             tracks the active theme (dark/light/blue) instead of showing
             the default white WPF chrome. DynamicResource never throws if a
             key is missing, so this is safe across VS versions.
             ============================================================ -->

        <!-- Text inputs: editor-dark background, themed text/caret/border. -->
        <Style TargetType="{x:Type TextBox}">
            <Setter Property="Background" Value="{DynamicResource {x:Static vsshell:VsBrushes.WindowKey}}" />
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}" />
            <Setter Property="CaretBrush" Value="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}" />
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsshell:VsBrushes.ComboBoxBorderKey}}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="3,2" />
        </Style>

        <!-- List surfaces. -->
        <Style TargetType="{x:Type ListBox}">
            <Setter Property="Background" Value="{DynamicResource {x:Static vsshell:VsBrushes.WindowKey}}" />
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}" />
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsshell:VsBrushes.ComboBoxBorderKey}}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <!-- List rows with themed hover / selection (default WPF uses a
             hard-coded light-blue highlight that clashes with dark mode). -->
        <Style TargetType="{x:Type ListBoxItem}">
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="2,2" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background"
                                        Value="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarMouseOverBackgroundBeginKey}}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background"
                                        Value="{DynamicResource {x:Static vsshell:VsBrushes.HighlightKey}}" />
                                <Setter Property="Foreground"
                                        Value="{DynamicResource {x:Static vsshell:VsBrushes.HighlightTextKey}}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tab strip + panel. -->
        <Style TargetType="{x:Type TabControl}">
            <Setter Property="Background" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBackgroundKey}}" />
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}" />
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsshell:VsBrushes.ComboBoxBorderKey}}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style TargetType="{x:Type TabItem}">
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTabTextKey}}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabItem}">
                        <Border x:Name="bd" Margin="0,0,2,0" Padding="9,4" BorderThickness="1,1,1,0"
                                Background="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTabGradientBeginKey}}"
                                BorderBrush="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTabBorderKey}}">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background"
                                        Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTabMouseOverBackgroundBeginKey}}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background"
                                        Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTabSelectedTabKey}}" />
                                <Setter Property="Foreground"
                                        Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTabSelectedTextKey}}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Default (bordered) push button, themed with hover / pressed / disabled states. -->
        <Style TargetType="{x:Type Button}">
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.ButtonTextKey}}" />
            <Setter Property="Background" Value="{DynamicResource {x:Static vsshell:VsBrushes.ButtonFaceKey}}" />
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsshell:VsBrushes.ComboBoxBorderKey}}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="7,2" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="bd" SnapsToDevicePixels="True"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background"
                                        Value="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarMouseOverBackgroundBeginKey}}" />
                                <Setter TargetName="bd" Property="BorderBrush"
                                        Value="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarSelectedBorderKey}}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background"
                                        Value="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarSelectedKey}}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground"
                                        Value="{DynamicResource {x:Static vsshell:VsBrushes.GrayTextKey}}" />
                                <Setter TargetName="bd" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Toolbar button = the themed button + a right margin. -->
        <Style TargetType="{x:Type Button}" x:Key="ToolButton" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="MinWidth" Value="24" />
        </Style>

        <!-- Inline "link" button (Diff / Hist / Stage / Discard): flat, link-coloured. -->
        <Style TargetType="{x:Type Button}" x:Key="LinkButton">
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.ControlLinkTextKey}}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Margin" Value="2,0,0,0" />
            <Setter Property="Padding" Value="4,0" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground"
                                        Value="{DynamicResource {x:Static vsshell:VsBrushes.ControlLinkTextHoverKey}}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground"
                                        Value="{DynamicResource {x:Static vsshell:VsBrushes.GrayTextKey}}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBlock" x:Key="SectionHeader">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,6,0,2" />
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}" />
        </Style>

        <!-- Double-click a changed file to open the side-by-side diff. -->
        <Style x:Key="ChangeItemContainerStyle" TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
            <EventSetter Event="MouseDoubleClick" Handler="OnChangeItemDoubleClick" />
        </Style>

        <!-- Double-click a file-history commit to diff that commit for the file. -->
        <Style x:Key="HistoryItemContainerStyle" TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
            <EventSetter Event="MouseDoubleClick" Handler="OnHistoryItemDoubleClick" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Repository selector -->
        <Grid Grid.Row="0" Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Repo:" VerticalAlignment="Center" Margin="0,0,4,0" />
            <TextBox Grid.Column="1" VerticalAlignment="Center"
                     Text="{Binding RepositoryPath, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="Full path to the git working tree (the folder that contains the .git directory)." />
            <Button Grid.Column="2" Content="Set" Style="{StaticResource ToolButton}" Margin="4,0,4,0"
                    Command="{Binding SetRepositoryCommand}" ToolTip="Use the folder above as the git repository." />
            <Button Grid.Column="3" Content="Auto" Style="{StaticResource ToolButton}"
                    Command="{Binding AutoDetectCommand}" ToolTip="Detect the git repository from the open solution." />
        </Grid>

        <!-- Branch + sync toolbar -->
        <Grid Grid.Row="1" Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Branch: " VerticalAlignment="Center" />
                <TextBlock Text="{Binding CurrentBranch}" FontWeight="Bold" VerticalAlignment="Center" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="Fetch" Style="{StaticResource ToolButton}" Command="{Binding FetchCommand}" />
                <Button Content="Pull" Style="{StaticResource ToolButton}" Command="{Binding PullCommand}" />
                <Button Content="Push" Style="{StaticResource ToolButton}" Command="{Binding PushCommand}" />
                <Button Content="⟳" Style="{StaticResource ToolButton}" Command="{Binding RefreshCommand}" ToolTip="Refresh" />
            </StackPanel>
        </Grid>

        <!-- Main tabs -->
        <TabControl Grid.Row="2" SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}">
            <!-- Changes -->
            <TabItem Header="Changes">
                <Grid Margin="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Commit box -->
                    <TextBox Grid.Row="0" MinHeight="48" MaxHeight="120"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Text="{Binding CommitMessage, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Commit message" />
                    <WrapPanel Grid.Row="1" Orientation="Horizontal" Margin="0,4,0,0">
                        <Button Content="Commit" Style="{StaticResource ToolButton}" Margin="0,0,4,4" Command="{Binding CommitCommand}" />
                        <Button Content="Commit &amp; Push" Style="{StaticResource ToolButton}" Margin="0,0,4,4" Command="{Binding CommitAndPushCommand}" />
                        <Button Content="Stage all" Style="{StaticResource ToolButton}" Margin="0,0,4,4" Command="{Binding StageAllCommand}" />
                        <Button Content="Unstage all" Style="{StaticResource ToolButton}" Margin="0,0,4,4" Command="{Binding UnstageAllCommand}" />
                    </WrapPanel>

                    <TextBlock Grid.Row="2" Style="{StaticResource SectionHeader}">
                        <Run Text="Staged Changes (" /><Run Text="{Binding StagedChanges.Count, Mode=OneWay}" /><Run Text=")" />
                    </TextBlock>
                    <ListBox Grid.Row="3" ItemsSource="{Binding StagedChanges}"
                             ItemContainerStyle="{StaticResource ChangeItemContainerStyle}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             HorizontalContentAlignment="Stretch">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid ToolTip="{Binding ToolTip}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="18" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding StatusGlyph}" FontWeight="Bold" />
                                    <TextBlock Grid.Column="1" Text="{Binding FileName}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                                        <Button Content="Diff" Style="{StaticResource LinkButton}"
                                                Command="{Binding DataContext.OpenDiffCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                CommandParameter="{Binding}" />
                                        <Button Content="Hist" Style="{StaticResource LinkButton}"
                                                Command="{Binding DataContext.ShowFileHistoryCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                CommandParameter="{Binding}" />
                                        <Button Content="Unstage" Style="{StaticResource LinkButton}"
                                                Command="{Binding DataContext.UnstageCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                CommandParameter="{Binding}" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <TextBlock Grid.Row="4" Style="{StaticResource SectionHeader}">
                        <Run Text="Changes (" /><Run Text="{Binding UnstagedChanges.Count, Mode=OneWay}" /><Run Text=")" />
                    </TextBlock>
                    <ListBox Grid.Row="5" ItemsSource="{Binding UnstagedChanges}"
                             ItemContainerStyle="{StaticResource ChangeItemContainerStyle}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             HorizontalContentAlignment="Stretch">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid ToolTip="{Binding ToolTip}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="18" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding StatusGlyph}" FontWeight="Bold" />
                                    <TextBlock Grid.Column="1" Text="{Binding FileName}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                                        <Button Content="Diff" Style="{StaticResource LinkButton}"
                                                Command="{Binding DataContext.OpenDiffCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                CommandParameter="{Binding}" />
                                        <Button Content="Hist" Style="{StaticResource LinkButton}"
                                                Command="{Binding DataContext.ShowFileHistoryCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                CommandParameter="{Binding}" />
                                        <Button Content="Stage" Style="{StaticResource LinkButton}"
                                                Command="{Binding DataContext.StageCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                CommandParameter="{Binding}" />
                                        <Button Content="Discard" Style="{StaticResource LinkButton}"
                                                Command="{Binding DataContext.DiscardCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                CommandParameter="{Binding}" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </TabItem>

            <!-- Branches -->
            <TabItem Header="Branches">
                <Grid Margin="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding NewBranchName, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="New branch name" />
                        <Button Grid.Column="1" Content="Create + checkout" Style="{StaticResource ToolButton}" Margin="4,0,0,0"
                                Command="{Binding CreateBranchCommand}" />
                    </Grid>
                    <ListBox Grid.Row="1" ItemsSource="{Binding Branches}"
                             HorizontalContentAlignment="Stretch">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" />
                                        <TextBlock Text="{Binding TrackingText}" Opacity="0.6" FontSize="11" />
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="Checkout" Style="{StaticResource LinkButton}"
                                            VerticalAlignment="Center"
                                            Visibility="{Binding IsCurrent, Converter={StaticResource InverseBoolToVis}}"
                                            Command="{Binding DataContext.CheckoutCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                            CommandParameter="{Binding}" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </TabItem>

            <!-- History -->
            <TabItem Header="History">
                <ListBox ItemsSource="{Binding Commits}" HorizontalContentAlignment="Stretch" Margin="4">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel ToolTip="{Binding ToolTip}" Margin="0,1">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding ShortHash}" FontFamily="Consolas" Opacity="0.7" Margin="0,0,6,0" />
                                    <TextBlock Text="{Binding Subject}" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Opacity="0.6">
                                    <TextBlock Text="{Binding Author}" FontSize="11" />
                                    <TextBlock Text=" — " FontSize="11" />
                                    <TextBlock Text="{Binding RelativeDate}" FontSize="11" />
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </TabItem>

            <!-- File History -->
            <TabItem Header="File History">
                <Grid Margin="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="{Binding FileHistoryTitle}" Style="{StaticResource SectionHeader}"
                               TextTrimming="CharacterEllipsis"
                               ToolTip="Use the 'Hist' button on a file, or right-click a file in Solution Explorer → 'Git for TFS: File History'." />
                    <ListBox Grid.Row="1" ItemsSource="{Binding FileHistoryCommits}"
                             ItemContainerStyle="{StaticResource HistoryItemContainerStyle}"
                             HorizontalContentAlignment="Stretch">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid ToolTip="{Binding ToolTip}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding ShortHash}" FontFamily="Consolas" Opacity="0.7" Margin="0,0,6,0" />
                                            <TextBlock Text="{Binding Subject}" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Opacity="0.6">
                                            <TextBlock Text="{Binding Author}" FontSize="11" />
                                            <TextBlock Text=" — " FontSize="11" />
                                            <TextBlock Text="{Binding RelativeDate}" FontSize="11" />
                                        </StackPanel>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="Diff" Style="{StaticResource LinkButton}" VerticalAlignment="Center"
                                            Command="{Binding DataContext.OpenCommitDiffCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                            CommandParameter="{Binding}" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Status bar -->
        <Border Grid.Row="3" Margin="0,4,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" TextTrimming="CharacterEllipsis" Opacity="0.85" />
                <TextBlock Grid.Column="1" Text="Working…" FontStyle="Italic"
                           Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>

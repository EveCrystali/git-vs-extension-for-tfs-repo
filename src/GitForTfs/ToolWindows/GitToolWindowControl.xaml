<UserControl x:Class="GitForTfs.ToolWindows.GitToolWindowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vsshell="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
             xmlns:imaging="clr-namespace:Microsoft.VisualStudio.Imaging;assembly=Microsoft.VisualStudio.Imaging"
             xmlns:catalog="clr-namespace:Microsoft.VisualStudio.Imaging;assembly=Microsoft.VisualStudio.ImageCatalog"
             xmlns:conv="clr-namespace:GitForTfs.Mvvm"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="340"
             Background="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBackgroundKey}}"
             Foreground="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}"
             FontFamily="{DynamicResource {x:Static vsshell:VsFonts.EnvironmentFontFamilyKey}}"
             FontSize="{DynamicResource {x:Static vsshell:VsFonts.EnvironmentFontSizeKey}}"
             TextOptions.TextFormattingMode="Display"
             Name="Root">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis" />
        <conv:EmptyStringToVisibilityConverter x:Key="EmptyToVis" />
        <conv:GitStatusToBrushConverter x:Key="StatusToBrush" />
        <conv:BoolToFontWeightConverter x:Key="BoolToWeight" />

        <!-- ============================================================
             Everything binds to Visual Studio environment colors/fonts so
             the window is indistinguishable from a built-in tool window in
             any theme. DynamicResource never throws if a key is missing.
             ============================================================ -->

        <Style TargetType="{x:Type TextBox}">
            <Setter Property="Background" Value="{DynamicResource {x:Static vsshell:VsBrushes.WindowKey}}" />
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}" />
            <Setter Property="CaretBrush" Value="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}" />
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsshell:VsBrushes.ComboBoxBorderKey}}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="3,2" />
        </Style>

        <Style TargetType="{x:Type ListBox}">
            <Setter Property="Background" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBackgroundKey}}" />
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        </Style>

        <!-- List rows: themed hover / selection matching VS (no white default). -->
        <Style TargetType="{x:Type ListBoxItem}">
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="4,3" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background"
                                        Value="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarMouseOverBackgroundBeginKey}}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background"
                                        Value="{DynamicResource {x:Static vsshell:VsBrushes.HighlightKey}}" />
                                <Setter Property="Foreground"
                                        Value="{DynamicResource {x:Static vsshell:VsBrushes.HighlightTextKey}}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type TabControl}">
            <Setter Property="Background" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBackgroundKey}}" />
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style TargetType="{x:Type TabItem}">
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTabTextKey}}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabItem}">
                        <Border x:Name="bd" Margin="0,0,1,0" Padding="10,5" BorderThickness="0,0,0,2"
                                Background="Transparent" BorderBrush="Transparent">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background"
                                        Value="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarMouseOverBackgroundBeginKey}}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush"
                                        Value="{DynamicResource {x:Static vsshell:VsBrushes.AccentMediumKey}}" />
                                <Setter Property="Foreground"
                                        Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTabSelectedTextKey}}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Bordered push button (primary actions like Commit). -->
        <Style TargetType="{x:Type Button}">
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.ButtonTextKey}}" />
            <Setter Property="Background" Value="{DynamicResource {x:Static vsshell:VsBrushes.ButtonFaceKey}}" />
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsshell:VsBrushes.ComboBoxBorderKey}}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="bd" SnapsToDevicePixels="True" CornerRadius="2"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background"
                                        Value="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarMouseOverBackgroundBeginKey}}" />
                                <Setter TargetName="bd" Property="BorderBrush"
                                        Value="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarSelectedBorderKey}}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background"
                                        Value="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarSelectedKey}}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground"
                                        Value="{DynamicResource {x:Static vsshell:VsBrushes.GrayTextKey}}" />
                                <Setter TargetName="bd" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Flat icon-only command button (toolbar + per-row actions), like a VS command bar glyph. -->
        <Style TargetType="{x:Type Button}" x:Key="IconButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="3" />
            <Setter Property="Margin" Value="1,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="bd" CornerRadius="3" SnapsToDevicePixels="True"
                                Background="{TemplateBinding Background}" BorderBrush="Transparent"
                                BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background"
                                        Value="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarMouseOverBackgroundBeginKey}}" />
                                <Setter TargetName="bd" Property="BorderBrush"
                                        Value="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarSelectedBorderKey}}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background"
                                        Value="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarSelectedKey}}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Section label, VS-style: small, semi-bold, slightly muted. -->
        <Style TargetType="TextBlock" x:Key="SectionHeader">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}" />
        </Style>

        <!-- Actions that only appear when the row is hovered (native VS behaviour). -->
        <Style TargetType="StackPanel" x:Key="RowActions">
            <Setter Property="Orientation" Value="Horizontal" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ChangeItemContainerStyle" TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
            <EventSetter Event="MouseDoubleClick" Handler="OnChangeItemDoubleClick" />
        </Style>

        <Style x:Key="HistoryItemContainerStyle" TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
            <EventSetter Event="MouseDoubleClick" Handler="OnHistoryItemDoubleClick" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ===== Repository + sync command bar ===== -->
        <Border Grid.Row="0" Padding="6,5"
                Background="{DynamicResource {x:Static vsshell:VsBrushes.CommandShelfBackgroundGradientKey}}"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBorderKey}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Repo path -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <imaging:CrispImage Grid.Column="0" Width="16" Height="16" Margin="0,0,5,0"
                                        VerticalAlignment="Center" Moniker="{x:Static catalog:KnownMonikers.GitRepository}" />
                    <TextBox Grid.Column="1" VerticalAlignment="Center"
                             Text="{Binding RepositoryPath, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Full path to the git working tree (the folder that contains the .git directory)." />
                    <Button Grid.Column="2" Style="{StaticResource IconButton}" Margin="4,0,0,0"
                            Command="{Binding SetRepositoryCommand}" ToolTip="Use the folder above as the git repository.">
                        <imaging:CrispImage Width="16" Height="16" Moniker="{x:Static catalog:KnownMonikers.Checkmark}" />
                    </Button>
                    <Button Grid.Column="3" Style="{StaticResource IconButton}"
                            Command="{Binding AutoDetectCommand}" ToolTip="Detect the git repository from the open solution.">
                        <imaging:CrispImage Width="16" Height="16" Moniker="{x:Static catalog:KnownMonikers.Property}" />
                    </Button>
                </Grid>

                <!-- Branch + fetch/pull/push/refresh -->
                <Grid Grid.Row="1" Margin="0,5,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <imaging:CrispImage Grid.Column="0" Width="16" Height="16" Margin="0,0,5,0"
                                        VerticalAlignment="Center" Moniker="{x:Static catalog:KnownMonikers.Branch}" />
                    <TextBlock Grid.Column="1" Text="{Binding CurrentBranch}" FontWeight="SemiBold"
                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis" ToolTip="{Binding CurrentBranch}" />
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button Style="{StaticResource IconButton}" Command="{Binding FetchCommand}" ToolTip="Fetch">
                            <imaging:CrispImage Width="16" Height="16" Moniker="{x:Static catalog:KnownMonikers.Fetch}" />
                        </Button>
                        <Button Style="{StaticResource IconButton}" Command="{Binding PullCommand}" ToolTip="Pull (fast-forward only)">
                            <imaging:CrispImage Width="16" Height="16" Moniker="{x:Static catalog:KnownMonikers.Pull}" />
                        </Button>
                        <Button Style="{StaticResource IconButton}" Command="{Binding PushCommand}" ToolTip="Push">
                            <imaging:CrispImage Width="16" Height="16" Moniker="{x:Static catalog:KnownMonikers.Push}" />
                        </Button>
                        <Button Style="{StaticResource IconButton}" Command="{Binding RefreshCommand}" ToolTip="Refresh">
                            <imaging:CrispImage Width="16" Height="16" Moniker="{x:Static catalog:KnownMonikers.Refresh}" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- ===== Tabs ===== -->
        <TabControl Grid.Row="2" Margin="0" SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}">
            <!-- Changes -->
            <TabItem Header="Changes">
                <Grid Margin="6,4,6,4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Commit message with a watermark -->
                    <Grid Grid.Row="0">
                        <TextBox x:Name="CommitBox" MinHeight="52" MaxHeight="120"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Text="{Binding CommitMessage, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="Enter a commit message" Margin="5,4,0,0"
                                   Foreground="{DynamicResource {x:Static vsshell:VsBrushes.GrayTextKey}}"
                                   IsHitTestVisible="False" VerticalAlignment="Top"
                                   Visibility="{Binding CommitMessage, Converter={StaticResource EmptyToVis}}" />
                    </Grid>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,5,0,2">
                        <Button Command="{Binding CommitCommand}" Margin="0,0,5,0" ToolTip="Commit staged changes">
                            <StackPanel Orientation="Horizontal">
                                <imaging:CrispImage Width="16" Height="16" Margin="0,0,4,0" Moniker="{x:Static catalog:KnownMonikers.Commit}" />
                                <TextBlock Text="Commit" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding CommitAndPushCommand}" ToolTip="Commit staged changes and push">
                            <StackPanel Orientation="Horizontal">
                                <imaging:CrispImage Width="16" Height="16" Margin="0,0,4,0" Moniker="{x:Static catalog:KnownMonikers.Push}" />
                                <TextBlock Text="Commit &amp; Push" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource IconButton}" Margin="6,0,0,0"
                                Command="{Binding GenerateCommitDiffCommand}"
                                ToolTip="Write the staged diff (git diff --cached) to a file and open it — paste it to an AI to draft a commit message">
                            <imaging:CrispImage Width="16" Height="16" Moniker="{x:Static catalog:KnownMonikers.Comment}" />
                        </Button>
                    </StackPanel>

                    <!-- Staged section -->
                    <Grid Grid.Row="2" Margin="0,6,0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource SectionHeader}">
                            <Run Text="Staged Changes (" /><Run Text="{Binding StagedChanges.Count, Mode=OneWay}" /><Run Text=")" />
                        </TextBlock>
                        <Button Grid.Column="1" Style="{StaticResource IconButton}"
                                Command="{Binding UnstageAllCommand}" ToolTip="Unstage all">
                            <imaging:CrispImage Width="16" Height="16" Moniker="{x:Static catalog:KnownMonikers.Remove}" />
                        </Button>
                    </Grid>
                    <ListBox Grid.Row="3" ItemsSource="{Binding StagedChanges}"
                             ItemContainerStyle="{StaticResource ChangeItemContainerStyle}"
                             HorizontalContentAlignment="Stretch">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid ToolTip="{Binding ToolTip}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding StatusGlyph}" FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               Foreground="{Binding StatusGlyph, Converter={StaticResource StatusToBrush}}" />
                                    <TextBlock Grid.Column="1" Text="{Binding FileName}" Margin="4,0,0,0"
                                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                    <StackPanel Grid.Column="2" Style="{StaticResource RowActions}">
                                        <Button Style="{StaticResource IconButton}" ToolTip="Compare with index"
                                                Command="{Binding DataContext.OpenDiffCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                CommandParameter="{Binding}">
                                            <imaging:CrispImage Width="15" Height="15" Moniker="{x:Static catalog:KnownMonikers.CompareFiles}" />
                                        </Button>
                                        <Button Style="{StaticResource IconButton}" ToolTip="File history"
                                                Command="{Binding DataContext.ShowFileHistoryCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                CommandParameter="{Binding}">
                                            <imaging:CrispImage Width="15" Height="15" Moniker="{x:Static catalog:KnownMonikers.History}" />
                                        </Button>
                                        <Button Style="{StaticResource IconButton}" ToolTip="Unstage"
                                                Command="{Binding DataContext.UnstageCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                CommandParameter="{Binding}">
                                            <imaging:CrispImage Width="15" Height="15" Moniker="{x:Static catalog:KnownMonikers.Remove}" />
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Unstaged section -->
                    <Grid Grid.Row="4" Margin="0,6,0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource SectionHeader}">
                            <Run Text="Changes (" /><Run Text="{Binding UnstagedChanges.Count, Mode=OneWay}" /><Run Text=")" />
                        </TextBlock>
                        <Button Grid.Column="1" Style="{StaticResource IconButton}"
                                Command="{Binding StageAllCommand}" ToolTip="Stage all">
                            <imaging:CrispImage Width="16" Height="16" Moniker="{x:Static catalog:KnownMonikers.Add}" />
                        </Button>
                    </Grid>
                    <ListBox Grid.Row="5" ItemsSource="{Binding UnstagedChanges}"
                             ItemContainerStyle="{StaticResource ChangeItemContainerStyle}"
                             HorizontalContentAlignment="Stretch">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid ToolTip="{Binding ToolTip}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding StatusGlyph}" FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               Foreground="{Binding StatusGlyph, Converter={StaticResource StatusToBrush}}" />
                                    <TextBlock Grid.Column="1" Text="{Binding FileName}" Margin="4,0,0,0"
                                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                    <StackPanel Grid.Column="2" Style="{StaticResource RowActions}">
                                        <Button Style="{StaticResource IconButton}" ToolTip="Compare with unmodified"
                                                Command="{Binding DataContext.OpenDiffCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                CommandParameter="{Binding}">
                                            <imaging:CrispImage Width="15" Height="15" Moniker="{x:Static catalog:KnownMonikers.CompareFiles}" />
                                        </Button>
                                        <Button Style="{StaticResource IconButton}" ToolTip="File history"
                                                Command="{Binding DataContext.ShowFileHistoryCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                CommandParameter="{Binding}">
                                            <imaging:CrispImage Width="15" Height="15" Moniker="{x:Static catalog:KnownMonikers.History}" />
                                        </Button>
                                        <Button Style="{StaticResource IconButton}" ToolTip="Discard changes"
                                                Command="{Binding DataContext.DiscardCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                CommandParameter="{Binding}">
                                            <imaging:CrispImage Width="15" Height="15" Moniker="{x:Static catalog:KnownMonikers.Undo}" />
                                        </Button>
                                        <Button Style="{StaticResource IconButton}" ToolTip="Stage"
                                                Command="{Binding DataContext.StageCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                CommandParameter="{Binding}">
                                            <imaging:CrispImage Width="15" Height="15" Moniker="{x:Static catalog:KnownMonikers.Add}" />
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </TabItem>

            <!-- Branches -->
            <TabItem Header="Branches">
                <Grid Margin="6,4,6,4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0">
                            <TextBox Text="{Binding NewBranchName, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="New branch name" Margin="5,0,0,0" IsHitTestVisible="False"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource {x:Static vsshell:VsBrushes.GrayTextKey}}"
                                       Visibility="{Binding NewBranchName, Converter={StaticResource EmptyToVis}}" />
                        </Grid>
                        <Button Grid.Column="1" Style="{StaticResource IconButton}" Margin="4,0,0,0"
                                Command="{Binding CreateBranchCommand}" ToolTip="Create branch and check it out">
                            <StackPanel Orientation="Horizontal">
                                <imaging:CrispImage Width="16" Height="16" Margin="0,0,3,0" Moniker="{x:Static catalog:KnownMonikers.NewBranch}" />
                                <TextBlock Text="Create" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </Grid>
                    <ListBox Grid.Row="1" ItemsSource="{Binding Branches}" HorizontalContentAlignment="Stretch">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <imaging:CrispImage Grid.Column="0" Width="16" Height="16" Margin="0,0,6,0"
                                                        VerticalAlignment="Center" Moniker="{x:Static catalog:KnownMonikers.Branch}" />
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontWeight="{Binding IsCurrent, Converter={StaticResource BoolToWeight}}" />
                                        <TextBlock Text="{Binding TrackingText}" Opacity="0.6" FontSize="11" />
                                    </StackPanel>
                                    <Button Grid.Column="2" Style="{StaticResource IconButton}" VerticalAlignment="Center"
                                            ToolTip="Check out this branch"
                                            Visibility="{Binding IsCurrent, Converter={StaticResource InverseBoolToVis}}"
                                            Command="{Binding DataContext.CheckoutCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                            CommandParameter="{Binding}">
                                        <imaging:CrispImage Width="16" Height="16" Moniker="{x:Static catalog:KnownMonikers.CheckOutForEdit}" />
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </TabItem>

            <!-- History -->
            <TabItem Header="History">
                <ListBox ItemsSource="{Binding Commits}" HorizontalContentAlignment="Stretch" Margin="6,4,6,4">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid ToolTip="{Binding ToolTip}" Margin="0,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <imaging:CrispImage Grid.Column="0" Width="16" Height="16" Margin="0,2,6,0"
                                                    VerticalAlignment="Top" Moniker="{x:Static catalog:KnownMonikers.Commit}" />
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding Subject}" TextTrimming="CharacterEllipsis" />
                                    <StackPanel Orientation="Horizontal" Opacity="0.6">
                                        <TextBlock Text="{Binding ShortHash}" FontFamily="Consolas" Margin="0,0,6,0" FontSize="11" />
                                        <TextBlock Text="{Binding Author}" FontSize="11" />
                                        <TextBlock Text=" · " FontSize="11" />
                                        <TextBlock Text="{Binding RelativeDate}" FontSize="11" />
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </TabItem>

            <!-- File History -->
            <TabItem Header="File History">
                <Grid Margin="6,4,6,4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="{Binding FileHistoryTitle}" Style="{StaticResource SectionHeader}"
                               Margin="0,0,0,4" TextTrimming="CharacterEllipsis"
                               ToolTip="Use the history icon on a file, or right-click a file in Solution Explorer → 'Git for TFS: File History'." />
                    <ListBox Grid.Row="1" ItemsSource="{Binding FileHistoryCommits}"
                             ItemContainerStyle="{StaticResource HistoryItemContainerStyle}"
                             HorizontalContentAlignment="Stretch">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid ToolTip="{Binding ToolTip}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <imaging:CrispImage Grid.Column="0" Width="16" Height="16" Margin="0,2,6,0"
                                                        VerticalAlignment="Top" Moniker="{x:Static catalog:KnownMonikers.Commit}" />
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding Subject}" TextTrimming="CharacterEllipsis" />
                                        <StackPanel Orientation="Horizontal" Opacity="0.6">
                                            <TextBlock Text="{Binding ShortHash}" FontFamily="Consolas" Margin="0,0,6,0" FontSize="11" />
                                            <TextBlock Text="{Binding Author}" FontSize="11" />
                                            <TextBlock Text=" · " FontSize="11" />
                                            <TextBlock Text="{Binding RelativeDate}" FontSize="11" />
                                        </StackPanel>
                                    </StackPanel>
                                    <Button Grid.Column="2" Style="{StaticResource IconButton}" VerticalAlignment="Center"
                                            ToolTip="Compare this commit for the file"
                                            Command="{Binding DataContext.OpenCommitDiffCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                            CommandParameter="{Binding}">
                                        <imaging:CrispImage Width="15" Height="15" Moniker="{x:Static catalog:KnownMonikers.CompareFiles}" />
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- ===== Status bar ===== -->
        <Border Grid.Row="3" Padding="6,3"
                Background="{DynamicResource {x:Static vsshell:VsBrushes.CommandShelfBackgroundGradientKey}}"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBorderKey}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center" Opacity="0.85" />
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                    <imaging:CrispImage Width="16" Height="16" Margin="0,0,4,0" Moniker="{x:Static catalog:KnownMonikers.StatusRunning}" />
                    <TextBlock Text="Working…" FontStyle="Italic" VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
